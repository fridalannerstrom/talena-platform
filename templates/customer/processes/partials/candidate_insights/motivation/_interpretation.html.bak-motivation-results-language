<!-- OVERALL INTERPRETATION -->
<section class="mt-4 purpose-fit-section">

  <h3 class="motivation-ai-section__title">
    Overall motivation interpretation
  </h3>

  <div
    class="motivation-ai-interpretation"
    data-motivation-ai-interpretation
  >
    {{ motivation_interpretation.interpretation }}
  </div>

</section>


<!-- EXPECTATION SETTING -->
<section
  class="
    border
    rounded-4
    p-3
    mt-4
    {% if not motivation_interpretation.expectation_setting %}
      d-none
    {% endif %}
  "
  data-motivation-ai-expectation-section
>

  <div class="d-flex align-items-start gap-3">

    <div class="flex-shrink-0">
      <i data-feather="message-circle"></i>
    </div>

    <div>

      <h3 class="mb-2 purpose-fit-section-title">
        Realistic expectation setting
      </h3>

      <div
        class="purpose-fit-summary"
        data-motivation-ai-expectation
      >{{ motivation_interpretation.expectation_setting }}</div>

    </div>

  </div>

</section>
<!-- ENGAGEMENT + CLARIFY -->
<div class="row g-4 mt-1">

  <!-- ENGAGEMENT CONDITIONS -->
  <div class="col-lg-6">

    <section
      class="
        purpose-fit-list-card
        purpose-fit-list-card--positive
        h-100
        {% if not motivation_interpretation.engagement_conditions %}
          d-none
        {% endif %}
      "
      data-motivation-ai-engagement-section
    >

      <div class="purpose-fit-section-title">
        Conditions likely to support engagement
      </div>

      <ul
        class="purpose-fit-list"
        data-motivation-ai-engagement
      >
        {% for item in motivation_interpretation.engagement_conditions %}

          <li>
            <span class="purpose-fit-list-icon">
              <i data-feather="zap"></i>
            </span>

            <span>{{ item }}</span>
          </li>

        {% endfor %}
      </ul>

    </section>

  </div>


  <!-- AREAS TO CLARIFY -->
  <div class="col-lg-6">

    <section
      class="
        purpose-fit-list-card
        purpose-fit-list-card--verify
        h-100
        {% if not motivation_interpretation.areas_to_clarify %}
          d-none
        {% endif %}
      "
      data-motivation-ai-clarify-section
    >

      <div class="purpose-fit-section-title">
        What to explore or clarify
      </div>

      <ul
        class="purpose-fit-list"
        data-motivation-ai-clarify
      >
        {% for item in motivation_interpretation.areas_to_clarify %}

          <li>
            <span class="purpose-fit-list-icon">
              <i data-feather="search"></i>
            </span>

            <span>{{ item }}</span>
          </li>

        {% endfor %}
      </ul>

    </section>

  </div>

</div>
<!-- /ENGAGEMENT + CLARIFY -->


<!-- CONTEXT NOTE -->
<div class="motivation-ai-context-note mt-4">

  <div class="motivation-ai-context-note__title">
    How Talena created this interpretation
  </div>

  <div data-motivation-ai-context-note>
    {{ motivation_interpretation.context_note }}
  </div>

</div>


<!-- DISCLAIMER -->
<div class="purpose-fit-disclaimer border-top pt-3 mt-4">

  <i data-feather="info"></i>

  <div>
    Motivation results describe possible sources of energy,
    engagement and preference. Less central factors are not
    weaknesses and do not indicate limited capability or poor values.
  </div>

</div>